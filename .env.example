# PulseWatch environment template
# Copy to .env for local development.

# App
APP_ENV=development
APP_BASE_URL=http://localhost:8000
APP_API_SECRET_KEY=replace_me
JWT_SECRET=replace_me

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pulsewatch

# Queue/Cache
REDIS_URL=redis://localhost:6379/0

# Storage
STORAGE_BASE_PATH=./data
# Optional S3/MinIO
S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=

# Browser capture
PLAYWRIGHT_HEADLESS=true
CAPTURE_TIMEOUT_SECONDS=45

# AI summarization (choose provider)
OPENROUTER_API_KEY=sk-or-...
ANTHROPIC_API_KEY=
AI_MODEL=
AI_MAX_TOKENS=500

# Alerts
DISCORD_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
